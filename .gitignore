# OS
.DS_Store
Thumbs.db

# Data generated by the app (stays local, never committed)
data/*.json
data/*.md
!data/.gitkeep
# Excepción: config.json es la configuración del frontend (URL del Worker, etc),
# debe versionarse aunque esté en data/ raíz.
!data/config.json

# Reports generated
reportes/*.md
reportes/*.html
!reportes/.gitkeep

# Weekly plans filled by PMs
planeaciones/*.md
!planeaciones/.gitkeep

# Excel templates and filled data
*.xlsx

# Editor
*.swp
*.swo
*~
